# Server
PORT=4311
NODE_ENV=development
SESSION_SECRET=change_this_to_a_long_random_secret

# Login (for local demo; set your own in production)
MARK_AUTH_USERNAME=your_username_here
MARK_AUTH_PASSWORD=your_strong_password_here

# Mark -> Gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Set to the model your account has access to, e.g. gemini-2.5-flash or gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview

# Optional custom system behavior for Mark
MARK_SYSTEM_PROMPT=You are Mark, the NorthStar Agency copilot. Prioritize actionable, evidence-first job search support.

# Server
PORT=4311
NODE_ENV=development
SESSION_SECRET=change_this_to_a_long_random_secret

# Login (required)
MARK_AUTH_USERNAME=your_username_here
MARK_AUTH_PASSWORD=your_strong_password_here

# Mark -> Gemini (server-side only)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
MARK_ALLOW_LOCAL_FALLBACK=true

# Optional custom system behavior
MARK_SYSTEM_PROMPT=You are Mark, the NorthStar Agency copilot. Prioritize actionable, evidence-first job search support.

# Abuse protection
MARK_IP_WINDOW_MS=300000
MARK_IP_LIMIT=60
MARK_USER_WINDOW_MS=300000
MARK_USER_WINDOW_LIMIT=20
MARK_USER_DAILY_LIMIT=300
LOGIN_MAX_ATTEMPTS=7
LOGIN_LOCK_MINUTES=15

# Context and memory
MARK_MAX_HISTORY_TURNS=12
MARK_MAX_CONTEXT_CHARS=24000
MARK_CONTEXT_CACHE_MS=300000
# Comma-separated project-relative files
MARK_CONTEXT_FILES=brain/CLIENT_BRIEF.md,brain/CASE_LOG.md,brain/CLIENT_SUCCESS_SOP.md,brain/ENFORCEMENT.md,reports/B_TIER_AUDIT_REPORT_2026-02-23.md
